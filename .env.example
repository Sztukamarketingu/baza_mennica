# Port aplikacji
PORT=3000

# Tajna wartość do podpisywania ciasteczka sesji.
# Wygeneruj np. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=zmien-mnie-na-dlugi-losowy-ciag

# Konto właściciela sklepu (jedyny użytkownik aplikacji)
ADMIN_EMAIL=wlasciciel@mennica.pl
# Hash hasła wygeneruj komendą: `npm run hash-password -- "TwojeHaslo123"`
ADMIN_PASSWORD_HASH=$2a$10$przykladowyhashzastapprawdziwym................

# Limit długości pojedynczego nagrania (sekundy)
MAX_RECORDING_SECONDS=300

# Publiczny URL aplikacji (używany w eksportach)
BASE_URL=https://baza-mennica.aikuznia.cloud

# Wymuszenie HTTPS-only ciasteczka sesji w produkcji (true/false)
SECURE_COOKIE=true

# Ścieżka do binarki ffmpeg (zwykle wystarczy domyślne `ffmpeg` w PATH)
FFMPEG_PATH=ffmpeg

# n8n / Airtable automation.
# Gdy N8N_WEBHOOK_URL i N8N_SHARED_SECRET są ustawione, aplikacja wyśle event
# po każdym zapisanym nagraniu. Ten sam sekret n8n używa do pobrania audio
# i callbacku z transkryptem.
N8N_WEBHOOK_URL=
N8N_SHARED_SECRET=
