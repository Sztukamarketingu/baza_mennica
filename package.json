{
  "name": "mennica-knowledge-collector",
  "version": "1.0.0",
  "description": "Aplikacja do zbierania bazy wiedzy (Q&A audio) dla chatbota mennica.pl",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "init": "npm run migrate && npm run seed",
    "hash-password": "node src/scripts/hash-password.js",
    "smoke-test": "node src/scripts/smoke-test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "connect-sqlite3": "^0.9.15",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "form-data": "^4.0.0"
  }
}
